<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Assignment Helper - Ultimate</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}body{font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);min-height:100vh;transition:background 0.3s ease}body.dark-mode{background:#1a1a1a}.floating-btn{position:fixed;bottom:30px;right:30px;width:60px;height:60px;background:#667eea;border:none;border-radius:50%;cursor:pointer;font-size:28px;z-index:9999;box-shadow:0 10px 30px rgba(102,126,234,0.4);transition:all 0.3s ease}.floating-btn:hover{transform:scale(1.1)}.floating-btn.active{background:#e74c3c}.side-panel{position:fixed;right:-420px;top:0;width:400px;height:100vh;background:white;box-shadow:-5px 0 30px rgba(0,0,0,0.2);transition:right 0.3s ease;z-index:10000;display:flex;flex-direction:column;overflow:hidden}.side-panel.open{right:0}.side-panel.dark-mode{background:#2c2c2c;color:#ecf0f1}.panel-header{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;padding:20px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}.panel-header h2{font-size:18px}.close-btn{background:rgba(255,255,255,0.2);border:none;color:white;font-size:24px;cursor:pointer;width:40px;height:40px;border-radius:50%;transition:all 0.3s ease}.close-btn:hover{background:rgba(255,255,255,0.4)}.panel-tabs{display:flex;gap:0;border-bottom:2px solid #ecf0f1;flex-shrink:0;overflow-x:auto}.panel-tabs button{flex:1;background:none;border:none;padding:12px;cursor:pointer;font-size:11px;font-weight:600;color:#7f8c8d;border-bottom:3px solid transparent;transition:all 0.3s ease;white-space:nowrap}.panel-tabs button.active{color:#667eea;border-bottom-color:#667eea}.panel-content{flex:1;overflow-y:auto;padding:20px}.tab-content{display:none}.tab-content.active{display:block}.search-box{width:100%;padding:10px;margin-bottom:15px;border:2px solid #ecf0f1;border-radius:6px;font-family:inherit}.side-panel.dark-mode .search-box{background:#3c3c3c;color:#ecf0f1;border-color:#555}.input-field{margin:15px 0;text-align:left}.input-field label{display:block;margin-bottom:5px;font-weight:600;color:#2c3e50;font-size:13px}.side-panel.dark-mode .input-field label{color:#ecf0f1}.input-field input,.input-field textarea,.input-field select{width:100%;padding:10px;border:2px solid #ecf0f1;border-radius:6px;font-family:inherit;font-size:13px}.side-panel.dark-mode .input-field input,.side-panel.dark-mode .input-field textarea,.side-panel.dark-mode .input-field select{background:#3c3c3c;color:#ecf0f1;border-color:#555}.input-field textarea{resize:vertical;min-height:80px}.btn{width:100%;padding:10px;margin:10px 0;border:none;border-radius:6px;cursor:pointer;font-weight:600;transition:all 0.3s ease}.btn-primary{background:#667eea;color:white}.btn-primary:hover{background:#5568d3}.btn-secondary{background:#ecf0f1;color:#2c3e50}.btn-secondary:hover{background:#bdc3c7}.task-item{background:#f0f0f0;padding:12px;margin:10px 0;border-radius:6px;border-left:4px solid #667eea;text-align:left}.side-panel.dark-mode .task-item{background:#3c3c3c;color:#ecf0f1}.task-item h4{margin-bottom:5px;font-size:14px}.task-item p{font-size:12px;opacity:0.7;margin-bottom:8px}.task-actions{display:flex;gap:5px}.task-actions button{flex:1;padding:6px;font-size:11px;border:none;border-radius:4px;cursor:pointer}.complete-btn{background:#27ae60;color:white}.delete-btn{background:#e74c3c;color:white}.response-box{background:#f0f7ff;padding:15px;border-radius:6px;margin-top:15px;border-left:4px solid #667eea;display:none}.side-panel.dark-mode .response-box{background:#3c3c3c}.response-box h4{margin-bottom:10px;color:#667eea}.response-box p{font-size:13px;line-height:1.6;white-space:pre-wrap;word-wrap:break-word}.chat-message{background:#f0f0f0;padding:10px;margin:8px 0;border-radius:6px;border-left:4px solid #667eea;font-size:12px}.side-panel.dark-mode .chat-message{background:#3c3c3c}.chat-message.user{background:#e8f4f8;border-left-color:#667eea}.side-panel.dark-mode .chat-message.user{background:#1a3a3a}.chat-time{font-size:10px;opacity:0.6;margin-top:5px}.stats-box{background:#f0f0f0;padding:15px;border-radius:6px;margin:10px 0;text-align:center}.side-panel.dark-mode .stats-box{background:#3c3c3c}.stats-box h4{color:#667eea;margin-bottom:10px}.stats-box p{font-size:24px;font-weight:bold;color:#667eea}.mode-toggle{position:fixed;top:20px;right:20px;background:white;border:none;padding:10px 20px;border-radius:20px;cursor:pointer;z-index:9998;font-weight:600}body.dark-mode .mode-toggle{background:#2c2c2c;color:#ecf0f1}.main{max-width:1200px;margin:0 auto;padding:40px 20px;text-align:center;color:white}.hero h1{font-size:48px;margin-bottom:20px}.hero p{font-size:18px;margin-bottom:30px}.features{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:25px;margin-top:50px}.feature-card{background:white;padding:30px;border-radius:12px;color:#2c3e50}body.dark-mode .feature-card{background:#2c2c2c;color:#ecf0f1}.feature-card h3{color:#667eea;margin-bottom:15px}@media(max-width:768px){.side-panel{width:100%;right:-100%}.hero h1{font-size:32px}}
    </style>
</head>
<body>
    <button class="mode-toggle" onclick="toggleDarkMode()">🌙 Dark Mode</button>
    <button class="floating-btn" id="floatingBtn" onclick="togglePanel()">💬</button>
    <div class="side-panel" id="sidePanel">
        <div class="panel-header">
            <h2>📚 AI Helper</h2>
            <button class="close-btn" onclick="togglePanel()">✕</button>
        </div>
        <div class="panel-tabs">
            <button class="tab-btn active" onclick="switchTab('dashboard')">Dashboard</button>
            <button class="tab-btn" onclick="switchTab('assignments')">Assignments</button>
            <button class="tab-btn" onclick="switchTab('help')">Help</button>
            <button class="tab-btn" onclick="switchTab('chat')">Chat</button>
            <button class="tab-btn" onclick="switchTab('tasks')">Tasks</button>
            <button class="tab-btn" onclick="switchTab('notes')">Notes</button>
        </div>
        <div class="panel-content">
            <div id="dashboard" class="tab-content active">
                <h3 style="margin-bottom:15px">📊 Dashboard</h3>
                <div class="stats-box"><h4>Total Assignments</h4><p id="totalAssignments">0</p></div>
                <div class="stats-box"><h4>Completed</h4><p id="completedAssignments">0</p></div>
                <div class="stats-box"><h4>Total Tasks</h4><p id="totalTasks">0</p></div>
                <div class="stats-box"><h4>Chat Messages</h4><p id="totalChats">0</p></div>
                <button class="btn btn-primary" onclick="exportData()">📥 Export Data</button>
                <button class="btn btn-secondary" onclick="clearAllData()">🗑️ Clear All</button>
            </div>
            <div id="assignments" class="tab-content">
                <h3 style="margin-bottom:15px">📝 Assignments</h3>
                <input type="text" class="search-box" id="assignmentSearch" placeholder="Search..." onkeyup="filterAssignments()">
                <div id="assignmentsList"></div>
                <button class="btn btn-primary" onclick="showAddAssignmentForm()">+ Add</button>
                <div id="addAssignmentForm" style="display:none;margin-top:15px">
                    <div class="input-field"><label>Name</label><input type="text" id="newAssignmentName" placeholder="Assignment name"></div>
                    <div class="input-field"><label>Due Date</label><input type="date" id="newAssignmentDue"></div>
                    <div class="input-field"><label>Priority</label><select id="newAssignmentPriority"><option value="low">Low</option><option value="medium" selected>Medium</option><option value="high">High</option></select></div>
                    <button class="btn btn-primary" onclick="addAssignment()">Save</button>
                    <button class="btn btn-secondary" onclick="hideAddAssignmentForm()">Cancel</button>
                </div>
            </div>
            <div id="help" class="tab-content">
                <h3 style="margin-bottom:15px">🤖 Get Help</h3>
                <div class="input-field"><label>Ask Question</label><textarea id="helpInput" placeholder="Ask anything..."></textarea></div>
                <button class="btn btn-primary" onclick="getHelp()">Get Answer</button>
                <div id="helpResponse" class="response-box"><h4>Answer:</h4><p id="helpText"></p><button class="btn btn-secondary" style="margin-top:10px" onclick="copyHelp()">📋 Copy</button></div>
            </div>
            <div id="chat" class="tab-content">
                <h3 style="margin-bottom:15px">💬 Chat History</h3>
                <input type="text" class="search-box" id="chatSearch" placeholder="Search..." onkeyup="filterChat()">
                <div id="chatHistory"></div>
                <button class="btn btn-secondary" onclick="clearChatHistory()">Clear History</button>
            </div>
            <div id="tasks" class="tab-content">
                <h3 style="margin-bottom:15px">📋 Tasks</h3>
                <input type="text" class="search-box" id="taskSearch" placeholder="Search..." onkeyup="filterTasks()">
                <div id="tasksList"></div>
                <button class="btn btn-primary" onclick="showAddTaskForm()">+ Add</button>
                <div id="addTaskForm" style="display:none;margin-top:15px">
                    <div class="input-field"><label>Task Name</label><input type="text" id="newTaskName" placeholder="Task name"></div>
                    <div class="input-field"><label>Priority</label><select id="newTaskPriority"><option value="low">Low</option><option value="medium" selected>Medium</option><option value="high">High</option></select></div>
                    <button class="btn btn-primary" onclick="addTask()">Save</button>
                    <button class="btn btn-secondary" onclick="hideAddTaskForm()">Cancel</button>
                </div>
            </div>
            <div id="notes" class="tab-content">
                <h3 style="margin-bottom:15px">📝 Notes</h3>
                <div id="notesList"></div>
                <button class="btn btn-primary" onclick="showAddNoteForm()">+ Add</button>
                <div id="addNoteForm" style="display:none;margin-top:15px">
                    <div class="input-field"><label>Title</label><input type="text" id="newNoteTitle" placeholder="Note title"></div>
                    <div class="input-field"><label>Content</label><textarea id="newNoteContent" placeholder="Write note..."></textarea></div>
                    <button class="btn btn-primary" onclick="addNote()">Save</button>
                    <button class="btn btn-secondary" onclick="hideAddNoteForm()">Cancel</button>
                </div>
            </div>
        </div>
    </div>
    <div class="main">
        <div class="hero">
            <h1>🎓 AI Assignment Helper</h1>
            <p>Your complete AI assistant for learning</p>
            <button class="btn btn-primary" style="width:200px;margin-top:20px" onclick="togglePanel()">Open Panel</button>
        </div>
        <div class="features">
            <div class="feature-card"><h3>📊 Dashboard</h3><p>Track progress</p></div>
            <div class="feature-card"><h3>📝 Assignments</h3><p>Manage work</p></div>
            <div class="feature-card"><h3>🤖 AI Help</h3><p>Get answers</p></div>
            <div class="feature-card"><h3>💬 Chat</h3><p>View history</p></div>
            <div class="feature-card"><h3>📋 Tasks</h3><p>Organize</p></div>
            <div class="feature-card"><h3>📝 Notes</h3><p>Save ideas</p></div>
        </div>
    </div>
    <script>
        let appData={assignments:[],tasks:[],notes:[],chatHistory:[]};function loadData(){try{const saved=localStorage.getItem('aiHelperData');if(saved){appData=JSON.parse(saved)}}catch(e){}updateAllDisplays()}function saveData(){try{localStorage.setItem('aiHelperData',JSON.stringify(appData))}catch(e){}}function togglePanel(){const panel=document.getElementById('sidePanel');const btn=document.getElementById('floatingBtn');panel.classList.toggle('open');btn.classList.toggle('active')}function switchTab(tabName){document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));document.getElementById(tabName).classList.add('active');event.target.classList.add('active')}function updateDashboard(){document.getElementById('totalAssignments').textContent=appData.assignments.length;document.getElementById('completedAssignments').textContent=appData.assignments.filter(a=>a.completed).length;document.getElementById('totalTasks').textContent=appData.tasks.length;document.getElementById('totalChats').textContent=appData.chatHistory.length}function showAddAssignmentForm(){document.getElementById('addAssignmentForm').style.display='block'}function hideAddAssignmentForm(){document.getElementById('addAssignmentForm').style.display='none'}function addAssignment(){const name=document.getElementById('newAssignmentName').value;const due=document.getElementById('newAssignmentDue').value;const priority=document.getElementById('newAssignmentPriority').value;if(name&&due){appData.assignments.push({id:Date.now(),name:name,due:due,priority:priority,completed:false});saveData();updateAssignmentsList();updateDashboard();document.getElementById('newAssignmentName').value='';document.getElementById('newAssignmentDue').value='';hideAddAssignmentForm()}else{alert('Please fill in all fields')}}function updateAssignmentsList(){const list=document.getElementById('assignmentsList');list.innerHTML='';if(appData.assignments.length===0){list.innerHTML='<p style="color:#7f8c8d;text-align:center">No assignments</p>';return}appData.assignments.forEach(assignment=>{const item=document.createElement('div');item.className='task-item';const priorityEmoji=assignment.priority==='high'?'🔴':assignment.priority==='medium'?'🟡':'🟢';item.innerHTML=`<h4>${priorityEmoji} ${assignment.name}</h4><p>Due: ${new Date(assignment.due).toLocaleDateString()}</p><div class="task-actions"><button class="complete-btn" onclick="completeAssignment(${assignment.id})">${assignment.completed?'✓ Done':'Complete'}</button><button class="delete-btn" onclick="deleteAssignment(${assignment.id})">Delete</button></div>`;list.appendChild(item)})}function filterAssignments(){const search=document.getElementById('assignmentSearch').value.toLowerCase();const list=document.getElementById('assignmentsList');list.innerHTML='';const filtered=appData.assignments.filter(a=>a.name.toLowerCase().includes(search));if(filtered.length===0){list.innerHTML='<p style="color:#7f8c8d;text-align:center">No results</p>';return}filtered.forEach(assignment=>{const item=document.createElement('div');item.className='task-item';const priorityEmoji=assignment.priority==='high'?'🔴':assignment.priority==='medium'?'🟡':'🟢';item.innerHTML=`<h4>${priorityEmoji} ${assignment.name}</h4><p>Due: ${new Date(assignment.due).toLocaleDateString()}</p><div class="task-actions"><button class="complete-btn" onclick="completeAssignment(${assignment.id})">${assignment.completed?'✓ Done':'Complete'}</button><button class="delete-btn" onclick="deleteAssignment(${assignment.id})">Delete</button></div>`;list.appendChild(item)})}function completeAssignment(id){const assignment=appData.assignments.find(a=>a.id===id);if(assignment){assignment.completed=!assignment.completed;saveData();updateAssignmentsList();updateDashboard()}}function deleteAssignment(id){appData.assignments=appData.assignments.filter(a=>a.id!==id);saveData();updateAssignmentsList();updateDashboard()}function showAddTaskForm(){document.getElementById('addTaskForm').style.display='block'}function hideAddTaskForm(){document.getElementById('addTaskForm').style.display='none'}function addTask(){const name=document.getElementById('newTaskName').value;const priority=document.getElementById('newTaskPriority').value;if(name){appData.tasks.push({id:Date.now(),name:name,priority:priority,completed:false});saveData();updateTasksList();updateDashboard();document.getElementById('newTaskName').value='';hideAddTaskForm()}else{alert('Please enter task name')}}function updateTasksList(){const list=document.getElementById('tasksList');list.innerHTML='';if(appData.tasks.length===0){list.innerHTML='<p style="color:#7f8c8d;text-align:center">No tasks</p>';return}appData.tasks.forEach(task=>{const item=document.createElement('div');item.className='task-item';const priorityEmoji=task.priority==='high'?'🔴':task.priority==='medium'?'🟡':'🟢';item.innerHTML=`<h4>${priorityEmoji} ${task.name}</h4><p>Priority: ${task.priority.toUpperCase()}</p><div class="task-actions"><button class="complete-btn" onclick="completeTask(${task.id})">${task.completed?'✓ Done':'Complete'}</button><button class="delete-btn" onclick="deleteTask(${task.id})">Delete</button></div>`;list.appendChild(item)})}function filterTasks(){const search=document.getElementById('taskSearch').value.toLowerCase();const list=document.getElementById('tasksList');list.innerHTML='';const filtered=appData.tasks.filter(t=>t.name.toLowerCase().includes(search));if(filtered.length===0){list.innerHTML='<p style="color:#7f8c8d;text-align:center">No results</p>';return}filtered.forEach(task=>{const item=document.createElement('div');item.className='task-item';const priorityEmoji=task.priority==='high'?'🔴':task.priority==='medium'?'🟡':'🟢';item.innerHTML=`<h4>${priorityEmoji} ${task.name}</h4><p>Priority: ${task.priority.toUpperCase()}</p><div class="task-actions"><button class="complete-btn" onclick="completeTask(${task.id})">${task.completed?'✓ Done':'Complete'}</button><button class="delete-btn" onclick="deleteTask(${task.id})">Delete</button></div>`;list.appendChild(item)})}function completeTask(id){const task=appData.tasks.find(t=>t.id===id);if(task){task.completed=!task.completed;saveData();updateTasksList();updateDashboard()}}function deleteTask(id){appData.tasks=appData.tasks.filter(t=>t.id!==id);saveData();updateTasksList();updateDashboard()}function showAddNoteForm(){document.getElementById('addNoteForm').style.display='block'}function hideAddNoteForm(){document.getElementById('addNoteForm').style.display='none'}function addNote(){const title=document.getElementById('newNoteTitle').value;const content=document.getElementById('newNoteContent').value;if(title&&content){appData.notes.push({id:Date.now(),title:title,content:content,date:new Date().toLocaleDateString()});saveData();updateNotesList();document.getElementById('newNoteTitle').value='';document.getElementById('newNoteContent').value='';hideAddNoteForm()}else{alert('Please fill in all fields')}}function updateNotesList(){const list=document.getElementById('notesList');list.innerHTML='';if(appData.notes.length===0){list.innerHTML='<p style="color:#7f8c8d;text-align:center">No notes</p>';return}appData.notes.forEach(note=>{const item=document.createElement('div');item.className='task-item';item.innerHTML=`<h4>${note.title}</h4><p>${note.content}</p><p style="font-size:10px;opacity:0.5">${note.date}</p><button class="delete-btn" style="width:100%;margin-top:8px" onclick="deleteNote(${note.id})">Delete</button>`;list.appendChild(item)})}function deleteNote(id){appData.notes=appData.notes.filter(n=>n.id!==id);saveData();updateNotesList()}function getHelp(){const input=document.getElementById('helpInput').value.trim().toLowerCase();if(!input){alert('Ask a question!');return}let response='';if(input.includes('1+1'))response='1 + 1 = 2';else if(input.includes('2+2'))response='2 + 2 = 4';else if(input.includes('3+3'))response='3 + 3 = 6';else if(input.includes('5+5'))response='5 + 5 = 10';else if(input.includes('2*2')||input.includes('2x2'))response='2 × 2 = 4';else if(input.includes('3*3')||input.includes('3x3'))response='3 × 3 = 9';else if(input.includes('5*5')||input.includes('5x5'))response='5 × 5 = 25';else if(input.includes('10/2'))response='10 ÷ 2 = 5';else if(input.includes('photosynthesis'))response='Photosynthesis: Plants use sunlight, water, and CO2 to create oxygen and glucose.\n\n6CO2 + 6H2O + light → C6H12O6 + 6O2';else if(input.includes('mitochondria'))response='Mitochondria: The powerhouse of the cell. Converts glucose and oxygen into ATP (energy).';else if(input.includes('dna'))response='DNA: Deoxyribonucleic Acid. Carries genetic instructions for life. Double helix structure.';else if(input.includes('gravity'))response='Gravity: Force that attracts objects with mass. On Earth: 9.8 m/s² acceleration.';else if(input.includes('atom'))response='Atom: Smallest unit of matter. Nucleus (protons+neutrons) + electrons orbiting.';else if(input.includes('american revolution'))response='American Revolution (1775-1783): Colonies declared independence from Britain.\n\nKey events:\n- Declaration of Independence (1776)\n- Battle of Yorktown (1781)\n- Treaty of Paris (1783)';else if(input.includes('world war 2')||input.includes('ww2'))response='World War 2 (1939-1945): Global conflict.\n\nKey facts:\n- Started: Germany invaded Poland\n- Ended: Atomic bombs on Japan\n- Deaths: ~70 million';else if(input.includes('french revolution'))response='French Revolution (1789-1799): Overthrew monarchy and feudal system. Led to Declaration of Rights of Man.';else if(input.includes('capital of france'))response='Capital of France: Paris';else if(input.includes('capital of japan'))response='Capital of Japan: Tokyo';else if(input.includes('capital of usa')||input.includes('capital of united states'))response='Capital of USA: Washington, D.C.';else if(input.includes('largest ocean'))response='Largest ocean: Pacific Ocean (~165 million km²)';else if(input.includes('largest country'))response='Largest country: Russia (~17.1 million km²)';else if(input.includes('shakespeare'))response='William Shakespeare (1564-1616): English playwright.\n\nFamous works:\n- Hamlet\n- Romeo and Juliet\n- Macbeth\n- A Midsummer Night\'s Dream';else if(input.includes('great gatsby'))response='The Great Gatsby: Novel by F. Scott Fitzgerald (1925). Jazz Age, themes of wealth and American Dream.';else if(input.includes('how to write')||input.includes('essay'))response='How to write an essay:\n\n1. Choose topic\n2. Research\n3. Create outline\n4. Write introduction with thesis\n5. Write body paragraphs with evidence\n6. Write conclusion\n7. Proofread';else if(input.includes('how to study'))response='Study tips:\n\n1. Find quiet place\n2. Take notes by hand\n3. Use active recall\n4. Space out studying\n5. Teach material to others\n6. Take breaks\n7. Get sleep';else response=`Question: "${input}"\n\nI can help with:\n- Math (1+1, 2*2, etc.)\n- Science (photosynthesis, DNA, gravity, atoms)\n- History (American Revolution, WW2, French Revolution)\n- Geography (capitals, oceans, countries)\n- Literature (Shakespeare, Great Gatsby)\n- Study tips and essay writing\n\nTry asking specific questions!`;appData.chatHistory.push({id:Date.now(),question:input,answer:response,date:new Date().toLocaleString()});saveData();document.getElementById('helpText').textContent=response;document.getElementById('helpResponse').style.display='block';updateChatHistory();updateDashboard()}function updateChatHistory(){const list=document.getElementById('chatHistory');list.innerHTML='';if(appData.chatHistory.length===0){list.innerHTML='<p style="color:#7f8c8d;text-align:center">No chat history</p>';return}appData.chatHistory.forEach(chat=>{const item=document.createElement('div');item.className='chat-message user';item.innerHTML=`<strong>Q:</strong> ${chat.question}<br><strong>A:</strong> ${chat.answer}<div class="chat-time">${chat.date}</div>`;list.appendChild(item)})}function filterChat(){const search=document.getElementById('chatSearch').value.toLowerCase();const list=document.getElementById('chatHistory');list.innerHTML='';const filtered=appData.chatHistory.filter(c=>c.question.toLowerCase().includes(search)||c.answer.toLowerCase().includes(search));if(filtered.length===0){list.innerHTML='<p style="color:#7f8c8d;text-align:center">No results</p>';return}filtered.forEach(chat=>{const item=document.createElement('div');item.className='chat-message user';item.innerHTML=`<strong>Q:</strong> ${chat.question}<br><strong>A:</strong> ${chat.answer}<div class="chat-time">${chat.date}</div>`;list.appendChild(item)})}function clearChatHistory(){if(confirm('Clear all chat history?')){appData.chatHistory=[];saveData();updateChatHistory();updateDashboard()}}function copyHelp(){const text=document.getElementById('helpText').textContent;navigator.clipboard.writeText(text).then(()=>{alert('✅ Copied!')}).catch(()=>{alert('Could not copy')})}function exportData(){const json=JSON.stringify(appData,null,2);const element=document.createElement('a');element.setAttribute('href','data:text/json;charset=utf-8,'+encodeURIComponent(json));element.setAttribute('download','ai-helper-data.json');element.style.display='none';document.body.appendChild(element);element.click();document.body.removeChild(element);alert('✅ Data exported!')}function clearAllData(){if(confirm('Clear ALL data? This cannot be undone!')){appData={assignments:[],tasks:[],notes:[],chatHistory:[]};localStorage.clear();updateAllDisplays();alert('✅ All data cleared!')}}function toggleDarkMode(){document.body.classList.toggle('dark-mode');document.getElementById('sidePanel').classList.toggle('dark-mode');localStorage.setItem('darkMode',document.body.classList.contains('dark-mode'))}function updateAllDisplays(){updateAssignmentsList();updateTasksList();updateNotesList();updateChatHistory();updateDashboard()}if(localStorage.getItem('darkMode')==
